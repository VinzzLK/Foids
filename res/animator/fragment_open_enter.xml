<?xml version="1.0" encoding="utf-8"?>
<!-- VoidLauncher: Fragment open enter - fixed pivot (no icon stretch) -->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fade in, delayed slightly so scale has time to show -->
    <objectAnimator
        android:interpolator="@android:interpolator/decelerate_quad"
        android:duration="50"
        android:valueFrom="0.0"
        android:valueTo="0.0"
        android:propertyName="alpha" />
    <objectAnimator
        android:interpolator="@android:interpolator/decelerate_cubic"
        android:duration="280"
        android:startDelay="30"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        android:propertyName="alpha" />
    <!-- Scale from center (no stretch): 0.92 -> 1.0 -->
    <objectAnimator
        android:interpolator="@android:interpolator/decelerate_cubic"
        android:duration="320"
        android:valueFrom="0.92"
        android:valueTo="1.0"
        android:propertyName="scaleX" />
    <objectAnimator
        android:interpolator="@android:interpolator/decelerate_cubic"
        android:duration="320"
        android:valueFrom="0.92"
        android:valueTo="1.0"
        android:propertyName="scaleY" />
</set>
