<?xml version="1.0" encoding="utf-8"?>
<!-- VoidLauncher: App close ENTER - launcher kembali, sinkron dgn wallpaper zoom IN -->
<!-- Durasi 280ms = sama dgn animateWallpaperZoom -->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fade in launcher -->
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:interpolator="@android:interpolator/decelerate_quad"
        android:duration="280" />
    <!-- Scale DOWN dari push-back state kembali normal (1.06 → 1.0) -->
    <!-- Ini visual complement dari wallpaper zoom IN -->
    <scale
        android:fromXScale="1.06"
        android:toXScale="1.0"
        android:fromYScale="1.06"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:interpolator="@android:interpolator/decelerate_quad"
        android:duration="280" />
</set>
