<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_parallax_settings.xml
     Fake Parallax Settings - traditional View layout (safe, no Compose slots)
     Background: #FF0D0D0D (Void dark)  Accent: #FF6C63FF (Void purple) -->
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FF0D0D0D"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Parallax Wallpaper"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fake zoom effect saat buka / tutup aplikasi"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- ─── SECTION: Wallpaper ─────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WALLPAPER"
            android:textColor="#FF6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp" />

        <!-- Wallpaper Zoom In Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1AFFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Parallax Wallpaper Zoom In"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:id="@id/tv_wp_zoom_in_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#FF6C63FF"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
            <SeekBar
                android:id="@id/sb_wp_zoom_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#FF6C63FF"
                android:thumbTint="#FF6C63FF" />
        </LinearLayout>

        <!-- Wallpaper Zoom Out Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1AFFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Parallax Wallpaper Zoom Out"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:id="@id/tv_wp_zoom_out_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#FF6C63FF"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
            <SeekBar
                android:id="@id/sb_wp_zoom_out"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#FF6C63FF"
                android:thumbTint="#FF6C63FF" />
        </LinearLayout>

        <!-- ─── SECTION: App Drawer ───────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APP DRAWER &amp; HOMESCREEN"
            android:textColor="#FF6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp" />

        <!-- Drawer Zoom In Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1AFFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Drawer Zoom In"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:id="@id/tv_dr_zoom_in_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#FF6C63FF"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
            <SeekBar
                android:id="@id/sb_dr_zoom_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#FF6C63FF"
                android:thumbTint="#FF6C63FF" />
        </LinearLayout>

        <!-- Drawer Zoom Out Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1AFFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Drawer Zoom Out"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:id="@id/tv_dr_zoom_out_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#FF6C63FF"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
            <SeekBar
                android:id="@id/sb_dr_zoom_out"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#FF6C63FF"
                android:thumbTint="#FF6C63FF" />
        </LinearLayout>

        <!-- Reset button -->
        <Button
            android:id="@id/btn_parallax_reset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Reset ke Default"
            android:textColor="#FFFFFFFF"
            android:background="#2AFF4B4B"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
